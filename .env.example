# Opslora service environment example.
# Copy to .env for direct local runs. Docker Compose and AKS should inject env directly.
# Values ending in _FILE can point to mounted secret files from Docker/Kubernetes/Key Vault CSI.
SERVICE_NAME=auth-service
ENVIRONMENT=development
LOG_LEVEL=INFO
ENV_FILE=

# Database modes:
# - local Docker: mysql+pymysql://root:<password>@mysql:3306/opslora_auth
# - local host:   mysql+pymysql://user:<password>@localhost:3306/opslora_auth
# - Azure:        injected from Key Vault as DATABASE_URL or DATABASE_URL_FILE
DATABASE_URL=mysql+pymysql://user:change-me@localhost:3306/opslora_auth
DATABASE_URL_FILE=
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE_SECONDS=1800
DATABASE_POOL_PRE_PING=true

# Shared JWT secret. In AKS inject from Azure Key Vault; do not commit real values.
JWT_SECRET_KEY=change-me
JWT_SECRET_KEY_FILE=
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
RABBITMQ_URL=amqp://guest:guest@localhost:5672//
RABBITMQ_URL_FILE=

# Storage is local by default. Azure Blob values are only required when STORAGE_PROVIDER=azure_blob.
STORAGE_PROVIDER=local
LOCAL_STORAGE_ROOT=/tmp/opslora-storage/auth-service
AZURE_STORAGE_ACCOUNT_URL=
AZURE_STORAGE_CONTAINER=org-assets
